# LLM backend: "ollama" for local dev, "groq" for deployed
LLM_BACKEND=ollama

# Ollama (local dev)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Groq (deployed)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=arxivmind

# Auth — RS256 for production; set JWT_ALGORITHM=HS256 for local dev without key files
# Generate RS256 keys: openssl genrsa -out keys/private.pem 2048 && openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# OAuth client credentials (set these to any values for local dev)
OAUTH_CLIENT_ID=arxivmind-client
OAUTH_CLIENT_SECRET=change-me-in-production

# Rate limiting
RATE_LIMIT_PER_MINUTE=10
